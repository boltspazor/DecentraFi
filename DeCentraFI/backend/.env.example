# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- PostgreSQL ---
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decentrafi
#
# Railway: in the backend service Variables, reference the Postgres plugin:
#   DATABASE_URL = ${{ Postgres.DATABASE_URL }}
# (Service name "Postgres" must match your Postgres service name.)
# Optional fallbacks (if your template exposes them):
# DATABASE_PRIVATE_URL=
# DATABASE_PUBLIC_URL=
#
# If the app cannot connect with SSL, set:
# DATABASE_SSL=true
# or PGSSLMODE=require

DATABASE_MAX_CONNECTIONS=10

# --- Redis (optional; cache is skipped if unset) ---
# Local:
REDIS_URL=redis://localhost:6379
#
# Railway: reference the Redis plugin:
#   REDIS_URL = ${{ Redis.REDIS_URL }}
# Or rely on discrete vars from Redis (supported by the app):
# REDISHOST=
# REDISPORT=6379
# REDISPASSWORD=
# REDISUSER=

# --- CORS: frontend origin(s), comma-separated ---
# Local:
FRONTEND_URL=http://localhost:5173,http://localhost:3000
# Railway example:
# FRONTEND_URL=https://your-frontend.up.railway.app

# --- App ---
ADMIN_WALLET=

CACHE_TTL_CAMPAIGNS_LIST_SECONDS=30
CACHE_TTL_CAMPAIGNS_SEARCH_SECONDS=20
CACHE_TTL_CAMPAIGN_DETAIL_SECONDS=20
CACHE_TTL_RECOMMENDATIONS_SECONDS=60
CACHE_TTL_REPORTS_SECONDS=30
CACHE_TTL_REPORTED_CAMPAIGNS_SECONDS=30
