# --- Server ---
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- PostgreSQL ---
# Local:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decentrafi
#
# Railway (required — without this the app would try 127.0.0.1 and fail with ECONNREFUSED):
# On the BACKEND service → Variables → New variable → "Reference" → pick your Postgres service → DATABASE_URL.
# Example name (must match your canvas):  DATABASE_URL = ${{ Postgres.DATABASE_URL }}
# If you only added Postgres to the project but never referenced it, DATABASE_URL is empty and the backend cannot connect.
# Optional fallbacks (if your template exposes them):
# DATABASE_PRIVATE_URL=
# DATABASE_PUBLIC_URL=
#
# If the app cannot connect with SSL, set:
# DATABASE_SSL=true
# or PGSSLMODE=require

DATABASE_MAX_CONNECTIONS=10

# --- Redis (optional; cache is skipped if unset) ---
# Local:
REDIS_URL=redis://localhost:6379
#
# Railway: reference the Redis plugin:
#   REDIS_URL = ${{ Redis.REDIS_URL }}
# Or rely on discrete vars from Redis (supported by the app):
# REDISHOST=
# REDISPORT=6379
# REDISPASSWORD=
# REDISUSER=

# --- CORS: frontend origin(s), comma-separated (https, no trailing slash) ---
# Local:
# FRONTEND_URL=http://localhost:5173,http://localhost:3000
# Production + local:
FRONTEND_URL=https://decentrafi-production.up.railway.app,http://localhost:5173,http://localhost:3000

# --- App ---
ADMIN_WALLET=

CACHE_TTL_CAMPAIGNS_LIST_SECONDS=30
CACHE_TTL_CAMPAIGNS_SEARCH_SECONDS=20
CACHE_TTL_CAMPAIGN_DETAIL_SECONDS=20
CACHE_TTL_RECOMMENDATIONS_SECONDS=60
CACHE_TTL_REPORTS_SECONDS=30
CACHE_TTL_REPORTED_CAMPAIGNS_SECONDS=30

# --- Seed demo data ---
# Runs automatically after `npm run build` if DATABASE_URL is set and Postgres accepts connections.
# Railway: the build step may not reach a private DB URL; use DATABASE_PUBLIC_URL for build or run `npm run seed` in a shell / release step.
# If the DB is down during build, seed is skipped (build still succeeds).
# Manual: npm run seed
# FORCE_SEED=true npm run seed   # truncate campaign tables and re-seed
