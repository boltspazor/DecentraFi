# Server
PORT=3001
HOST=0.0.0.0
# Use "development" locally, "production" for deploys
NODE_ENV=development

# Database
# Local: postgresql://localhost:5432/decentrafi  (or use docker compose which injects a container URL)
DATABASE_URL=postgresql://localhost:5432/decentrafi
# Optional: limit pool size (default pg is 10; use 5–10 on Railway free tier)
# DATABASE_MAX_CONNECTIONS=5

# Frontend URL(s) for CORS (comma-separated if multiple)
# Local: http://localhost:5173
# Docker: http://localhost:3000
# Production: https://your-frontend.railway.app
FRONTEND_URL=http://localhost:5173,http://localhost:3000

# Redis (optional). If unset, caching is disabled.
REDIS_URL=redis://localhost:6379

# Admin wallet (optional). Enables creator/campaign verification endpoints.
# Must be a 0x... address. For local dev you can set it to your own wallet.
ADMIN_WALLET=

# Quadratic Funding matching pool (optional; wei). Used by /api/qf endpoints if query param is not provided.
MATCHING_POOL_WEI=0

# Cache TTLs (seconds). Tune based on traffic & freshness needs.
CACHE_TTL_CAMPAIGNS_LIST_SECONDS=30
CACHE_TTL_CAMPAIGNS_SEARCH_SECONDS=20
CACHE_TTL_CAMPAIGN_DETAIL_SECONDS=20
CACHE_TTL_RECOMMENDATIONS_SECONDS=60
CACHE_TTL_REPORTS_SECONDS=30
CACHE_TTL_REPORTED_CAMPAIGNS_SECONDS=30
