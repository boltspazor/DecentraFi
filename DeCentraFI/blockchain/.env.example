# RPC (required for deploy to public networks)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
# MAINNET_RPC_URL=https://eth.llamarpc.com

# Deployer key (required for sepolia/mainnet deploy; never commit real keys)
PRIVATE_KEY=0x

# Railway / runtime
PORT=3000

# Optional: Railway pre-deploy (see railway.toml + scripts/railway-predeploy.js)
# RAILWAY_RUN_DEPLOY=true
# DEPLOY_NETWORK=sepolia
