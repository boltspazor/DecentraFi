# Sepolia RPC (default: public)
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Deployer private key (required for deploy:sepolia). Never commit real keys.
# PRIVATE_KEY=0x...

# After deploying (npm run deploy / deploy:sepolia), store addresses here for reference:
CAMPAIGN_FACTORY_ADDRESS=
GOV_TOKEN_ADDRESS=
GOVERNOR_ADDRESS=
TIMELOCK_ADDRESS=
PLATFORM_CONFIG_ADDRESS=
