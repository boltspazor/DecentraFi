# Copy to `.env.docker` and use: docker compose --env-file .env.docker up --build
# After deploying CampaignFactory from decentrafi/blockchain, paste addresses here.

# Must match backend ADMIN_WALLET (same wallet can moderate admin UI)
ADMIN_WALLET=0xYourAdminWallet
VITE_ADMIN_WALLET=0xYourAdminWallet

# Sepolia chain in browser (default 11155111)
VITE_CHAIN_ID=11155111

# From `npx hardhat run scripts/deploy.ts --network sepolia` (or mainnet)
VITE_CAMPAIGN_FACTORY_ADDRESS_SEPOLIA=0x...
VITE_CAMPAIGN_FACTORY_ADDRESS_MAINNET=
