# Backend API (Vite build-time var)
# Local (non-docker): http://localhost:3001
# Docker (served frontend container talks to backend container): http://backend:3001 (set via docker-compose build arg)
# Production: https://your-backend.railway.app
VITE_API_URL=http://localhost:3001

# Chain / RPC (Sepolia for testing; mainnet/polygon/arbitrum for production)
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://rpc.sepolia.org
VITE_POLYGON_RPC_URL=
VITE_ARBITRUM_RPC_URL=

# Contract (Campaign factory on the chain you use)
VITE_CAMPAIGN_FACTORY_ADDRESS=0x...

# Optional: DAO addresses (if/when you add frontend governance UI)
VITE_GOVERNOR_ADDRESS=
VITE_TIMELOCK_ADDRESS=
VITE_GOV_TOKEN_ADDRESS=
VITE_PLATFORM_CONFIG_ADDRESS=

# WalletConnect (optional; get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
