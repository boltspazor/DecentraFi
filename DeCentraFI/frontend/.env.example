# Backend API (Vite build-time var). Strongly recommended on Railway.
# Local: http://localhost:3001
VITE_API_URL=http://localhost:3001
# Production builds: if you omit VITE_API_URL, the app uses a built-in fallback + optional:
# VITE_PRODUCTION_API_URL=https://loyal-wonder-production-230a.up.railway.app

# Chains / RPC (Sepolia + Ethereum mainnet only)
VITE_RPC_URL=https://rpc.sepolia.org
VITE_MAINNET_RPC_URL=

# Transaction confirmations to wait for before treating tx as final.
# 1 is fine for Sepolia/local; consider 2-3 for production chains.
VITE_TX_CONFIRMATIONS=1

# Safety switch: keep this OFF to avoid accidentally using real mainnet funds.
# Set to "true" only if you intentionally want to allow chainId=1.
VITE_ALLOW_MAINNET=false

# Contract (Campaign factory per chain)
VITE_CAMPAIGN_FACTORY_ADDRESS_SEPOLIA=0x...
VITE_CAMPAIGN_FACTORY_ADDRESS_MAINNET=0x...

# Optional: DAO addresses (if/when you add frontend governance UI)
VITE_GOVERNOR_ADDRESS=
VITE_TIMELOCK_ADDRESS=
VITE_GOV_TOKEN_ADDRESS=
VITE_PLATFORM_CONFIG_ADDRESS=

# WalletConnect (optional; get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
