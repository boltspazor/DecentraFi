# Backend API (set at build time; use your Railway backend URL in production)
VITE_API_URL=https://your-backend.railway.app

# Chain / RPC (Sepolia for testing; mainnet/polygon/arbitrum for production)
VITE_CHAIN_ID=11155111
VITE_RPC_URL=https://rpc.sepolia.org
VITE_POLYGON_RPC_URL=
VITE_ARBITRUM_RPC_URL=

# Contract (Campaign factory on the chain you use)
VITE_CAMPAIGN_FACTORY_ADDRESS=0x...

# WalletConnect (optional; get from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
