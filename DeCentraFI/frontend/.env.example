# Backend API
VITE_API_URL=http://localhost:3001

# Sepolia – required for app
VITE_CHAIN_ID=11155111
# Optional: Sepolia RPC (default uses public)
# VITE_RPC_URL=https://rpc.sepolia.org

# Deployed CampaignFactory address (from blockchain deploy:sepolia)
VITE_CAMPAIGN_FACTORY_ADDRESS=

# Optional: WalletConnect project ID (from https://cloud.walletconnect.com)
# If set, WalletConnect connector is enabled in addition to MetaMask.
# VITE_WALLETCONNECT_PROJECT_ID=
